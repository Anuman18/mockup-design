// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model City {
  id     Int     @id @default(autoincrement())
  name   String
  state  String
  status String  @default("active")
  venues Venue[]

  @@map("cities")
}

model Venue {
  id      Int         @id @default(autoincrement())
  cityId  Int         @map("city_id")
  name    String
  address String
  city    City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  halls   VenueHall[]

  @@map("venues")
}

model VenueHall {
  id           Int     @id @default(autoincrement())
  venueId      Int     @map("venue_id")
  name         String
  length       Float   @default(0)
  width        Float   @default(0)
  height       Float   @default(0)
  capacity     Int     @default(0)
  baseImageUrl String? @map("base_image_url")
  centerMaskX  Int     @default(0) @map("center_mask_x")
  centerMaskY  Int     @default(0) @map("center_mask_y")
  centerMaskWidth Int  @default(0) @map("center_mask_width")
  centerMaskHeight Int @default(0) @map("center_mask_height")
  leftMaskX    Int     @default(0) @map("left_mask_x")
  leftMaskY    Int     @default(0) @map("left_mask_y")
  leftMaskWidth Int    @default(0) @map("left_mask_width")
  leftMaskHeight Int   @default(0) @map("left_mask_height")
  rightMaskX   Int     @default(0) @map("right_mask_x")
  rightMaskY   Int     @default(0) @map("right_mask_y")
  rightMaskWidth Int   @default(0) @map("right_mask_width")
  rightMaskHeight Int  @default(0) @map("right_mask_height")
  floorPlanUrl   String?          @map("floor_plan_url")
  refPhotoUrl1   String?          @map("ref_photo_url_1")
  refPhotoUrl2   String?          @map("ref_photo_url_2")
  venue        Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("venue_halls")
}

model BrandingTemplate {
  id           Int    @id @default(autoincrement())
  templateName String @map("template_name")
  logos        Logo[]

  @@map("branding_templates")
}

model Logo {
  id         Int              @id @default(autoincrement())
  templateId Int              @map("template_id")
  logoName   String           @map("logo_name")
  logoUrl    String?          @map("logo_url")
  template   BrandingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("logos")
}

model StageTemplate {
  id    Int    @id @default(autoincrement())
  name  String
  value String
  type  String @default("stage")

  @@map("stage_templates")
}

model SeatingTemplate {
  id    Int    @id @default(autoincrement())
  name  String
  value String
  type  String @default("seating")

  @@map("seating_templates")
}

model User {
  id           Int                  @id @default(autoincrement())
  email        String               @unique
  passwordHash String               @map("password_hash")
  name         String
  roleId       Int                  @map("role_id")
  status       String               @default("active") // "active", "suspended"
  lastLogin    DateTime?            @map("last_login")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  
  role         Role                 @relation(fields: [roleId], references: [id])
  sessions     Session[]
  resetTokens  PasswordResetToken[]

  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id        String   @id @default(uuid())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
